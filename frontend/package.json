{
  "name": "simplifica-frontend",
  "version": "1.0.0",
  "type": "module",
  "description": "Frontend para Simplifica - Sistema de gestão de portfólio de processos, riscos e cadeia de valor",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .vue,.ts",
    "format": "prettier --write src"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "pinia": "^2.3.0",
    "vuetify": "^3.7.5",
    "@mdi/font": "^7.4.47",
    "axios": "^1.7.9",
    "vue3-google-login": "^2.0.31",
    "@azure/msal-browser": "^3.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "vite": "^6.0.7",
    "vue-tsc": "^2.2.0",
    "typescript": "~5.7.2",
    "sass": "^1.85.0",
    "eslint": "^9.18.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.2",
    "vitest": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "jsdom": "^25.0.1",
    "vite-plugin-vuetify": "^2.0.4"
  }
}
