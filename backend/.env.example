# ========== DATABASE ==========
DB_HOST=postgres
DB_PORT=5432
DB_NAME=simplifica
DB_USER=admin
DB_PASSWORD=<change-me>

# ========== OAUTH2 ==========
OAUTH_GOOGLE_CLIENT_ID=<your-client-id>
OAUTH_GOOGLE_CLIENT_SECRET=<your-secret>
OAUTH_MICROSOFT_CLIENT_ID=<your-client-id>
OAUTH_MICROSOFT_CLIENT_SECRET=<your-secret>
OAUTH_REDIRECT_BASE_URL=http://localhost:8080/api

# CORS configuration (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ========== JWT ==========
# Generate 256-bit key: openssl rand -base64 32
JWT_SECRET=<generate-256-bit-key>
JWT_EXPIRATION_MS=86400000

# ========== SERVER ==========
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# ========== SPRING ==========
SPRING_PROFILES_ACTIVE=dev

# ========== FEATURES ==========
# Enable email notifications for user-institution assignments
EMAIL_NOTIFICATIONS_ENABLED=false

# ========== EMAIL CONFIGURATION ==========
# SMTP configuration (when EMAIL_NOTIFICATIONS_ENABLED=true)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_AUTH=true
# SMTP_STARTTLS_ENABLE=true
# EMAIL_FROM=noreply@simplifica.com
# EMAIL_FROM_NAME=Simplifica

# ========== STORAGE CONFIGURATION ==========
# Storage provider: local (filesystem) or s3 (AWS S3/MinIO)
STORAGE_PROVIDER=local

# Local storage configuration
STORAGE_LOCAL_BASE_PATH=/var/simplifica/uploads
STORAGE_LOCAL_PUBLIC_URL=http://localhost:8080/api/public/uploads

# Maximum file size in MB
STORAGE_MAX_FILE_SIZE_MB=5

# Allowed file extensions for uploads (comma-separated)
STORAGE_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp
