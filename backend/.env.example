# ========== DATABASE ==========
DB_HOST=postgres
DB_PORT=5432
DB_NAME=simplifica
DB_USER=admin
DB_PASSWORD=<change-me>

# ========== OAUTH2 ==========
OAUTH_GOOGLE_CLIENT_ID=<your-client-id>
OAUTH_GOOGLE_CLIENT_SECRET=<your-secret>
OAUTH_MICROSOFT_CLIENT_ID=<your-client-id>
OAUTH_MICROSOFT_CLIENT_SECRET=<your-secret>
OAUTH_REDIRECT_BASE_URL=http://localhost:8080/api

# CORS configuration (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ========== JWT ==========
# Generate 256-bit key: openssl rand -base64 32
JWT_SECRET=<generate-256-bit-key>
JWT_EXPIRATION_MS=86400000

# ========== SERVER ==========
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# ========== SPRING ==========
SPRING_PROFILES_ACTIVE=dev

# ========== FEATURES ==========
# Enable email notifications for user-institution assignments
EMAIL_NOTIFICATIONS_ENABLED=false

# ========== EMAIL CONFIGURATION ==========
# SMTP configuration (when EMAIL_NOTIFICATIONS_ENABLED=true)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_AUTH=true
# SMTP_STARTTLS_ENABLE=true
# EMAIL_FROM=noreply@simplifica.com
# EMAIL_FROM_NAME=Simplifica

# ========== STORAGE CONFIGURATION (Flysystem-style) ==========
# Storage provider: local, dropbox, googledrive
# Switch storage by changing this single variable
STORAGE_PROVIDER=local

# Local/Filesystem Storage (default)
# Used when STORAGE_PROVIDER=local
STORAGE_FILESYSTEM_ROOT=/tmp/simplifica/storage

# Dropbox Storage (only used when STORAGE_PROVIDER=dropbox)
# Get access token at: https://www.dropbox.com/developers/apps
# 1. Create Dropbox app
# 2. Generate access token
# 3. Configure below:
# STORAGE_DROPBOX_ACCESS_TOKEN=your-dropbox-token-here
# STORAGE_DROPBOX_BASE_PATH=/simplifica

# Google Drive Storage (only used when STORAGE_PROVIDER=googledrive)
# Create Service Account at: https://console.cloud.google.com
# 1. Create project and enable Google Drive API
# 2. Create Service Account and download credentials JSON
# 3. Configure below:
# STORAGE_GOOGLEDRIVE_CREDENTIALS_PATH=/path/to/credentials.json
# STORAGE_GOOGLEDRIVE_BASE_FOLDER_NAME=Simplifica
